# Exemplo de configuração — copie para .env e ajuste. NUNCA versione o .env real.
# Gere segredos fortes (ex.: `openssl rand -base64 32`).

# --- Banco (Postgres em produção) ---
POSTGRES_USER=sereno
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=sereno
# Opcional: sobrescrever a URL completa (senão é montada a partir das vars acima).
# DATABASE_URL=postgresql+psycopg://sereno:troque-esta-senha@db:5432/sereno

# --- Redis (rate limit, denylist de jti, fila) ---
REDIS_URL=redis://redis:6379/0

# --- Segredos da aplicação ---
JWT_SECRET=troque-por-um-segredo-de-32+bytes
PII_ENC_KEY=troque-por-base64-de-32-bytes    # ex.: openssl rand -base64 32
ALLOCATION_SEED=troque-por-semente-de-alocacao

# Chave SELADA A/B->condição. Custodiar SEPARADAMENTE (cofre/KMS); só abrir no data lock.
ARM_CONDITION_MAP=A:active,B:sham

# --- E-mail (OTP do participante + alerta de evento adverso) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@sereno.example
TEAM_NOTIFY_EMAIL=
