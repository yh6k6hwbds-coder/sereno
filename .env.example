# Exemplo de configuração — copie para .env e ajuste. NUNCA versione o .env real.
# Gere segredos fortes (ex.: `openssl rand -base64 32`).

# --- Ambiente ---
# dev (default): defaults de conveniência valem (mapa selado default, OTP no console se
# EMAIL_DEV_CONSOLE=1). production/prod: liga o guard de startup (app/core/config.py), que
# RECUSA subir sem a chave selada configurada ou com EMAIL_DEV_CONSOLE ligado.
APP_ENV=dev

# --- Banco (Postgres em produção) ---
POSTGRES_USER=sereno
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=sereno
# Opcional: sobrescrever a URL completa (senão é montada a partir das vars acima).
# DATABASE_URL=postgresql+psycopg://sereno:troque-esta-senha@db:5432/sereno

# --- Redis (rate limit, denylist de jti, fila) ---
REDIS_URL=redis://redis:6379/0
# Postura quando o Redis está fora (ADR-079): 1=fail-open (padrão, prioriza
# disponibilidade — não derruba login/OTP/auth); 0=fail-closed (prioriza a defesa: 429/401).
# SECURITY_FAIL_OPEN=1

# --- Segredos da aplicação ---
JWT_SECRET=troque-por-um-segredo-de-32+bytes
PII_ENC_KEY=troque-por-base64-de-32-bytes    # ex.: openssl rand -base64 32
ALLOCATION_SEED=troque-por-semente-de-alocacao

# Chave SELADA A/B->condição. NÃO É UM EXEMPLO A COPIAR: o valor real é um SORTEIO
# custodiado (ex.: A:sham,B:active OU A:active,B:sham — decidido pelo custodiante, tipicamente
# a orientadora), conhecido só por ele e aberto no data lock. Custodiar SEPARADAMENTE
# (cofre/KMS); em produção, setar como secret — o deploy RECUSA subir sem ela (ver ADR-077).
# Em dev, deixe VAZIO/ausente: o código usa um default só-dev (A:active,B:sham).
# ARM_CONDITION_MAP=

# --- Entrega de áudio (E3/ADR-082) ---
# inline (default): o backend transmite o WAV pelo caminho autenticado (comportamento A1).
# signed-url: GET /sessions/{id}/audio responde 302 p/ uma URL assinada de curta duração
# em /v1/audio/{content_hash} (capability = assinatura, sem Authorization). Prepara offload.
# AUDIO_DELIVERY=inline
# Chave dedicada p/ assinar as URLs de áudio (HMAC). Se ausente, deriva do JWT_SECRET.
# AUDIO_URL_SIGNING_KEY=troque-por-um-segredo-de-32+bytes
# AUDIO_URL_TTL_S=300        # validade da URL assinada, em segundos (padrão 300)
# AUDIO_CACHE_DIR=           # diretório do cache de WAV materializado (padrão <backend>/.audio_cache)

# --- Vestíveis (E2/ADR-084) — seam de ingestão ---
# null (default): aceita e DESCARTA as leituras (seam preparado, não persiste). memory: guarda
# em memória (teste/demo). Persistência real é um adaptador futuro (dado de saúde = sensível).
# WEARABLE_SINK=null

# --- E-mail (OTP do participante + alerta de evento adverso) ---
# Provedores comuns: 587 = STARTTLS (default); 465 = SSL implícito (autodetectado, ou
# force com SMTP_USE_SSL=1). Sem SMTP em produção, o OTP não é entregue (não vaza, mas o
# participante não recebe). Em dev, EMAIL_DEV_CONSOLE=1 imprime o código no console.
SMTP_HOST=
SMTP_PORT=587
# SMTP_USE_SSL=            # 1 para SSL implícito quando o provedor não usa 587/STARTTLS
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@sereno.example
TEAM_NOTIFY_EMAIL=
# EMAIL_DEV_CONSOLE=1      # DEV apenas — imprime o OTP no console. O guard recusa em produção.
